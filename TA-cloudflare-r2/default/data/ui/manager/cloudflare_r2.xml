<endpoint name="data/inputs/cloudflare_r2">
  <header>Cloudflare R2 Log Ingestion</header>
  <breadcrumb>
    <parent hidecurrent="False">datainputstats</parent>
    <name>Cloudflare R2</name>
  </breadcrumb>

  <elements>

    <!-- ============================================================ -->
    <!-- Input name + enabled status (shown on list and create views) -->
    <!-- ============================================================ -->
    <element name="nameField" type="fieldset">
      <view name="list"/>
      <view name="create"/>
      <elements>
        <element name="name" label="Input Name">
          <view name="list"/>
          <view name="create"/>
        </element>
        <element name="disabled" type="checkbox" label="Disable input">
          <view name="create"/>
          <view name="edit"/>
          <view name="list"/>
          <key name="exampleText">Leave unchecked to enable the input immediately after saving.</key>
        </element>
      </elements>
    </element>

    <!-- ============================================================ -->
    <!-- R2 Connection -->
    <!-- ============================================================ -->
    <element name="connectionFields" type="fieldset">
      <key name="legend">Cloudflare R2 Connection</key>
      <view name="edit"/>
      <view name="create"/>
      <elements>

        <element name="account_id" type="textfield" label="Cloudflare Account ID">
          <view name="edit"/>
          <view name="create"/>
          <key name="exampleText">32-character hex string (from your Cloudflare dashboard URL or R2 overview page)</key>
          <key name="requiredIfVisible">true</key>
        </element>

        <element name="access_key_id" type="textfield" label="R2 Access Key ID">
          <view name="edit"/>
          <view name="create"/>
          <key name="exampleText">Generate via: Cloudflare Dashboard > R2 > Manage R2 API Tokens</key>
          <key name="requiredIfVisible">true</key>
        </element>

        <element name="secret_access_key" type="password" label="R2 Secret Access Key">
          <view name="edit"/>
          <view name="create"/>
          <key name="exampleText">Shown once at token creation. Stored encrypted by Splunk.</key>
          <key name="requiredIfVisible">true</key>
        </element>

        <element name="bucket_name" type="textfield" label="R2 Bucket Name">
          <view name="edit"/>
          <view name="create"/>
          <key name="exampleText">e.g. cloudflare-managed-c9c00975</key>
          <key name="requiredIfVisible">true</key>
        </element>

        <element name="key_prefix" type="textfield" label="Key Prefix (optional)">
          <view name="edit"/>
          <view name="create"/>
          <key name="exampleText">Scope to one dataset, e.g. gateway_dns/ or http_requests/. Leave blank for all objects.</key>
        </element>

      </elements>
    </element>

    <!-- ============================================================ -->
    <!-- Collection Settings -->
    <!-- ============================================================ -->
    <element name="collectionFields" type="fieldset">
      <key name="legend">Collection Settings</key>
      <view name="edit"/>
      <view name="create"/>
      <elements>

        <element name="interval" type="textfield" label="Polling Interval (seconds)">
          <view name="edit"/>
          <view name="create"/>
          <key name="exampleText">How often to check R2 for new files. Default: 300 (5 minutes)</key>
        </element>

        <element name="verify_ssl" type="checkbox" label="Verify SSL Certificate">
          <view name="edit"/>
          <view name="create"/>
          <key name="exampleText">Recommended: enabled. Disable only if your network performs TLS inspection and you cannot add the CA to the trust store.</key>
        </element>

      </elements>
    </element>

    <!-- ============================================================ -->
    <!-- Source Type -->
    <!-- ============================================================ -->
    <element name="sourcetypeFields" type="fieldset">
      <key name="legend">Source Type</key>
      <view name="list"/>
      <view name="edit"/>
      <view name="create"/>
      <elements>

        <element name="sourcetype" type="textfield" label="Source type">
          <view name="list"/>
          <view name="edit"/>
          <view name="create"/>
          <key name="exampleText">Recommended values for Cloudflare App for Splunk (4501) compatibility:
  cloudflare:dns     - Zero Trust Gateway DNS logs
  cloudflare:http    - Zero Trust Gateway HTTP logs
  cloudflare:json    - Zone-level HTTP Request logs
  cloudflare:access  - Zero Trust Access logs
  cloudflare:audit   - Cloudflare Audit logs</key>
        </element>

      </elements>
    </element>

    <!-- ============================================================ -->
    <!-- Advanced: Index selection -->
    <!-- ============================================================ -->
    <element name="spl-ctrl_EnableAdvanced" type="checkbox" label="More settings"
             class="spl-mgr-advanced-switch">
      <view name="edit"/>
      <view name="create"/>
      <onChange>
        <key name="_action">showonly</key>
        <key name="0">NONE</key>
        <key name="1">ALL</key>
        <group_set>
          <group name="advanced"/>
        </group_set>
      </onChange>
    </element>

    <element name="advanced" type="fieldset" class="spl-mgr-advanced-options">
      <view name="edit"/>
      <view name="create"/>
      <elements>

        <element name="indexField" type="fieldset">
          <key name="legend">Index</key>
          <view name="edit"/>
          <view name="create"/>
          <elements>
            <element name="index" type="select" label="Index">
              <view name="edit"/>
              <view name="create"/>
              <key name="dynamicOptions" type="dict">
                <key name="keyName">title</key>
                <key name="keyValue">title</key>
                <key name="splunkSource">/data/indexes</key>
                <key name="splunkSourceParams" type="dict">
                  <key name="search">'isInternal=false disabled=false'</key>
                  <key name="count">-1</key>
                </key>
              </key>
            </element>
          </elements>
        </element>

      </elements>
    </element>

  </elements>
</endpoint>
